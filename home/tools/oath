if [[ $# -eq 0 ]]; then
    notify-send "Error" "Usage: oath <serial> [serial...]"
    exit 1
fi

accounts=""
for serial in "$@"; do
    device_accounts=$(ykman --device "$serial" oath accounts code 2>&1) || {
        notify-send "Warning" "Failed to read from device $serial"
        continue
    }
    if [[ -n "$device_accounts" ]]; then
        accounts+="${device_accounts}"$'\n'
    fi
done

accounts=$(echo "$accounts" | sed '/^$/d')

if [[ -z "$accounts" ]]; then
    notify-send "Error" "No OTP accounts found on any device."
    exit 1
fi

selected=$(echo "$accounts" | fuzzel --dmenu --prompt "Select OTP Account:")

if [[ -z "$selected" ]]; then
    notify-send "Info" "No selection made."
    exit 0
fi

code=$(echo "$selected" | awk '{print $NF}')
account="${selected% "$code"}"

echo -n "$code" | wl-copy
notify-send "OTP Copied" "The OTP code for \"$account\" has been copied to the clipboard."
